generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("USER")
  devices   Device[]
  createdAt DateTime @default(now())
}

model Device {
  id        String   @id @default(uuid())
  token     String   @unique
  platform  String?
  model     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}